# ── NINE.OS environment variables ────────────────────────────────
# Copy this file to .env.local and fill the values from your
# Supabase project: Dashboard → Project Settings → API.

# Public — safe to expose to the browser (protected by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Site URL used in auth links (production: your Vercel URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── SERVER-ONLY secret (no NEXT_PUBLIC_ prefix → never bundled to the
# browser; the module that reads it is additionally guarded by the
# `server-only` package). Used exclusively for teacher-initiated account
# administration: creating student accounts & resetting passwords.
# NEVER commit the real value. On Vercel, add it as a normal (non-public)
# environment variable.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
